-- Перетаскивание
local dragging, dragStart, startPos
Header.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = Main.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        Main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

-- Обновление статистики
local collectCount = 0
local sessionTime = 0

task.spawn(function()
    while wait(1) do
        pcall(function()
            if toggleStates["AutoFarm"] then
                collectCount = collectCount + math.random(1, 3)
            end
            sessionTime = sessionTime + 1

            local mins = math.floor(sessionTime / 60)
            local secs = sessionTime % 60
            SessionLabel.Text = string.format("Session %02d:%02d", mins, secs)

            statLabels[1].Text = string.format("%dс", sessionTime)
            statLabels[2].Text = tostring(collectCount)
            local speed = sessionTime > 0 and math.floor(collectCount / (sessionTime / 60)) or 0
            statLabels[3].Text = speed .. " / мин"
            statLabels[4].Text = toggleStates["AutoFarm"] and "Фармлю" or "Ожидание"
        end)
    end
end)
