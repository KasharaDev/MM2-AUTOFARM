    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.RightControl or input.KeyCode == Enum.KeyCode.P then
        guiVisible = not guiVisible
        Main.Visible = true
        if guiVisible then
            Main.Size = UDim2.new(0, 0, 0, 0)
