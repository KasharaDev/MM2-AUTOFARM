-- ==================== ПЕРЕТАСКИВАНИЕ ====================
local dragObject, dragStartPos, objectStartPos

local function startDrag(obj, input)
    dragObject = obj
    dragStartPos = input.Position
    objectStartPos = obj.Position
end

local function updateDrag(input)
    if dragObject then
        local delta = input.Position - dragStartPos
        dragObject.Position = UDim2.new(
            objectStartPos.X.Scale, objectStartPos.X.Offset + delta.X,
            objectStartPos.Y.Scale, objectStartPos.Y.Offset + delta.Y
        )
    end
end

local function endDrag()
    dragObject = nil
    dragStartPos = nil
    objectStartPos = nil
end

Header.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        startDrag(Main, input)
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        updateDrag(input)
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        endDrag()
    end
end)

