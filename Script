local function createTabButton(name, id, icon, order, locked)
    local btn = Instance.new("TextButton")
    btn.Parent = Sidebar
    btn.BackgroundColor3 = Color3.fromRGB(10, 14, 10)
    btn.BorderSizePixel = 0
    btn.Size = UDim2.new(1, 0, 0, 35)
    btn.Font = Enum.Font.GothamSemibold
    btn.Text = "  " .. icon .. "  " .. name
    btn.TextColor3 = Color3.fromRGB(150, 170, 150)
    btn.TextSize = 13
    btn.TextXAlignment = Enum.TextXAlignment.Left
    btn.AutoButtonColor = false
    btn.LayoutOrder = order
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 6)
    corner.Parent = btn
    
    local highlight = Instance.new("Frame")
    highlight.Parent = btn
    highlight.BackgroundColor3 = Color3.fromRGB(80, 200, 80)
    highlight.BorderSizePixel = 0
    highlight.Position = UDim2.new(0, 0, 0, 4)
    highlight.Size = UDim2.new(0, 3, 1, -8)
    highlight.Visible = false
    local hCorner = Instance.new("UICorner")
    hCorner.CornerRadius = UDim.new(0, 2)
    hCorner.Parent = highlight

    if locked then
        btn.TextTransparency = 0.4
        btn.Text = "  🔒  " .. name
    end

    btn.MouseEnter:Connect(function()
        if not locked and id ~= activeTab then
            TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(25, 38, 25)}):Play()
        end
    end)
    btn.MouseLeave:Connect(function()
        if id ~= activeTab then
            TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(10, 14, 10)}):Play()
        end
    end)

    btn.MouseButton1Click:Connect(function()
        if not locked then switchTab(id) end
    end)

    return btn, highlight
end

