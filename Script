-- Обновление статистики
local collectCount = 0
local sessionTime = 0

task.spawn(function()
    while wait(5) do
        pcall(function()
            if toggleStates["AutoFarm"] then
                collectCount = collectCount + math.random(1, 5)
                sessionTime = sessionTime + 5
            end
            -- Обновляем текст статистики
            for _, child in ipairs(StatsFrame:GetChildren()) do
                if child:IsA("TextLabel") then
                    if child.Text:find("Сессия:") then
                        child.Text = "Сессия: " .. sessionTime .. "с"
                    elseif child.Text:find("Всего:") then
                        child.Text = "Всего: " .. collectCount
                    elseif child.Text:find("Скорость:") then
                        local speed = toggleStates["AutoFarm"] and math.floor(collectCount / math.max(sessionTime / 60, 0.1)) or 0
                        child.Text = "Скорость: " .. speed .. " / мин"
                    elseif child.Text:find("Статус:") then
                        child.Text = toggleStates["AutoFarm"] and "Статус: Фармлю" or "Статус: Ожидание"
                    end
                end
            end
        end)
    end
end)

-- Перетаскивание окна
local dragging, dragStart, startPos
TopBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

TopBar.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
