TogglesLabel.Font = Enum.Font.GothamBold
TogglesLabel.Text = "Функции"
TogglesLabel.TextColor3 = palette.textSecondary
TogglesLabel.TextSize = 12
TogglesLabel.TextXAlignment = Enum.TextXAlignment.Left
TogglesLabel.LayoutOrder = 2

local togglesData = {
    {name = "Автофарм", desc = "Автоматический сбор монет", key = "AutoFarm", default = false},
    {name = "Авто-респавн", desc = "Мгновенное возрождение", key = "AutoRespawn", default = true},
    {name = "Анти-флинг", desc = "Защита от отбрасывания", key = "AntiFling", default = true},
    {name = "Избегать убийцу", desc = "Автоматический отход от убийцы", key = "AvoidMurder", default = true},
    {name = "Авто-флинг", desc = "Отбрасывать всех игроков", key = "AutoFling", default = true},
}

local toggleStates = {}
for i, tog in ipairs(togglesData) do
    toggleStates[tog.key] = tog.default

    local ToggleCard = Instance.new("Frame")
    ToggleCard.Parent = AutoFarmContent
    ToggleCard.BackgroundColor3 = palette.surface
    ToggleCard.BorderSizePixel = 0
    ToggleCard.Size = UDim2.new(0.9, 0, 0, 48)
    ToggleCard.LayoutOrder = i + 2
    local ToggleCorner = Instance.new("UICorner")
    ToggleCorner.CornerRadius = UDim.new(0, 10)
    ToggleCorner.Parent = ToggleCard

    local ToggleStroke = Instance.new("UIStroke")
    ToggleStroke.Parent = ToggleCard
    ToggleStroke.Color = palette.border
    ToggleStroke.Thickness = 1
    ToggleStroke.Transparency = 0.5

    local ToggleName = Instance.new("TextLabel")
    ToggleName.Parent = ToggleCard
    ToggleName.BackgroundTransparency = 1
    ToggleName.Position = UDim2.new(0, 16, 0, 6)
    ToggleName.Size = UDim2.new(0.7, 0, 0, 18)
    ToggleName.Font = Enum.Font.GothamBold
    ToggleName.Text = tog.name
    ToggleName.TextColor3 = palette.text
    ToggleName.TextSize = 13
    ToggleName.TextXAlignment = Enum.TextXAlignment.Left

    local ToggleDesc = Instance.new("TextLabel")
    ToggleDesc.Parent = ToggleCard
    ToggleDesc.BackgroundTransparency = 1
    ToggleDesc.Position = UDim2.new(0, 16, 0, 25)
    ToggleDesc.Size = UDim2.new(0.7, 0, 0, 16)
    ToggleDesc.Font = Enum.Font.Gotham
    ToggleDesc.Text = tog.desc
    ToggleDesc.TextColor3 = palette.textMuted
    ToggleDesc.TextSize = 10
    ToggleDesc.TextXAlignment = Enum.TextXAlignment.Left

    -- Modern Switch
    local Switch = Instance.new("TextButton")
    Switch.Parent = ToggleCard
    Switch.BackgroundColor3 = tog.default and palette.accent or Color3.fromRGB(50, 50, 60)
    Switch.BorderSizePixel = 0
    Switch.Position = UDim2.new(0.85, 0, 0, 12)
    Switch.Size = UDim2.new(0, 44, 0, 24)
    Switch.Text = ""
    Switch.AutoButtonColor = false
    Switch.ZIndex = 10
    local SwitchCorner = Instance.new("UICorner")
    SwitchCorner.CornerRadius = UDim.new(0, 12)
    SwitchCorner.Parent = Switch

    local Knob = Instance.new("Frame")
    Knob.Parent = Switch
    Knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    Knob.BorderSizePixel = 0
    Knob.Size = UDim2.new(0, 18, 0, 18)
    Knob.Position = tog.default and UDim2.new(0.5, 0, 0.125, 0) or UDim2.new(0.08, 0, 0.125, 0)
    local KnobCorner = Instance.new("UICorner")
    KnobCorner.CornerRadius = UDim.new(0, 9)
    KnobCorner.Parent = Knob

    Switch.MouseButton1Click:Connect(function()
        toggleStates[tog.key] = not toggleStates[tog.key]
        if toggleStates[tog.key] then
            TweenService:Create(Switch, TweenInfo.new(0.2), {BackgroundColor3 = palette.accent}):Play()
            TweenService:Create(Knob, TweenInfo.new(0.2), {Position = UDim2.new(0.5, 0, 0.125, 0)}):Play()
        else
            TweenService:Create(Switch, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(50, 50, 60)}):Play()
            TweenService:Create(Knob, TweenInfo.new(0.2), {Position = UDim2.new(0.08, 0, 0.125, 0)}):Play()
        end
    end)
end

AutoFarmContent.CanvasSize = UDim2.new(0, 0, 0, 100 + #togglesData * 60)

-- ==================== WORKER FUNCTIONS ====================
local collectCount = 0
local sessionTime = 0

-- Auto Farm
task.spawn(function()
    while task.wait(0.3) do
        pcall(function()
            if toggleStates["AutoFarm"] and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                local coins = getCoins()
                for _, coin in ipairs(coins) do
                    if coin and coin.Parent then
                        firetouchinterest(player.Character.HumanoidRootPart, coin, 0)
                        task.wait()
                        firetouchinterest(player.Character.HumanoidRootPart, coin, 1)
                        collectCount = collectCount + 1
                    end
                end
            end
        end)
    end
end)

-- Auto Respawn
task.spawn(function()
    while task.wait(0.5) do
        pcall(function()
            if toggleStates["AutoRespawn"] then
                if player.Character and player.Character:FindFirstChild("Humanoid") then
                    if player.Character.Humanoid.Health <= 0 then
                        player.Character:BreakJoints()
                    end
                end
            end
        end)
    end
end)

-- Anti Fling
task.spawn(function()
    while task.wait(0.1) do
        pcall(function()
            if toggleStates["AntiFling"] and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                player.Character.HumanoidRootPart.Velocity = Vector3.new(0, 0, 0)
                player.Character.HumanoidRootPart.RotVelocity = Vector3.new(0, 0, 0)
            end
        end)
    end
end)

-- Avoid Murderer
task.spawn(function()
    while task.wait(0.3) do
        pcall(function()
            if toggleStates["AvoidMurder"] and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                local murderer = getMurderer()
                if murderer and murderer.Character and murderer.Character:FindFirstChild("HumanoidRootPart") then
                    local dist = (player.Character.HumanoidRootPart.Position - murderer.Character.HumanoidRootPart.Position).Magnitude
                    if dist < 30 then
                        local dir = (player.Character.HumanoidRootPart.Position - murderer.Character.HumanoidRootPart.Position).Unit
                        player.Character.HumanoidRootPart.CFrame = player.Character.HumanoidRootPart.CFrame + dir * 5
                    end
                end
            end
        end)
    end
end)

-- Auto Fling
task.spawn(function()
    while task.wait(0.5) do
        pcall(function()
            if toggleStates["AutoFling"] and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                for _, p in ipairs(Players:GetPlayers()) do
                    if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                        local vel = (p.Character.HumanoidRootPart.Position - player.Character.HumanoidRootPart.Position).Unit * 100
                        vel = vel + Vector3.new(0, 50, 0)
                        p.Character.HumanoidRootPart.Velocity = vel
                    end
                end
            end
        end)
    end
end)

-- Stats and FPS Updater
task.spawn(function()
    while task.wait(1) do
        pcall(function()
            sessionTime = sessionTime + 1
            local mins = math.floor(sessionTime / 60)
            local secs = sessionTime % 60
            statValues[1].Text = string.format("%02d:%02d", mins, secs)
            statValues[2].Text = tostring(collectCount)
            local speed = sessionTime > 0 and math.floor(collectCount / (sessionTime / 60)) or 0
            statValues[3].Text = speed .. "/мин"
            statValues[4].Text = toggleStates["AutoFarm"] and "Активен" or "Ожидание"
            statValues[4].TextColor3 = toggleStates["AutoFarm"] and palette.success or palette.warning
            FPSLabel.Text = math.floor(1 / RunService.RenderStepped:Wait()) .. " FPS · v2.0"
        end)
    end
end)
