    local dragObject, dragStartPos, objectStartPos, isDragging = nil, nil, nil, false

    local function startDrag(input)
        isDragging = true
        dragObject = Main
        dragStartPos = input.Position
        objectStartPos = Main.Position
    end

    local function updateDrag(input)
        if isDragging and dragObject then
            local delta = input.Position - dragStartPos
            TweenService:Create(dragObject, TweenInfo.new(0.05, Enum.EasingStyle.Quad), {
                Position = UDim2.new(
                    objectStartPos.X.Scale,
                    objectStartPos.X.Offset + delta.X,
                    objectStartPos.Y.Scale,
                    objectStartPos.Y.Offset + delta.Y
                )
            }):Play()
        end
    end

    local function endDrag()
        isDragging = false
        dragObject = nil
        dragStartPos = nil
        objectStartPos = nil
    end

    Header.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
