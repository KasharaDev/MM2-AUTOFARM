    KnobShadow.Transparency = 0.5

    Switch.MouseButton1Click:Connect(function()
        toggleStates[tog.key] = not toggleStates[tog.key]
        local state = toggleStates[tog.key]
        if state then
            TweenService:Create(Switch, TweenInfo.new(0.2), {BackgroundColor3 = colors.switchOn}):Play()
            TweenService:Create(Knob, TweenInfo.new(0.2), {Position = UDim2.new(0.5, 0, 0.14, 0)}):Play()
            TweenService:Create(Indicator, TweenInfo.new(0.2), {BackgroundColor3 = colors.green}):Play()
        else
            TweenService:Create(Switch, TweenInfo.new(0.2), {BackgroundColor3 = colors.switchOff}):Play()
            TweenService:Create(Knob, TweenInfo.new(0.2), {Position = UDim2.new(0.08, 0, 0.14, 0)}):Play()
            TweenService:Create(Indicator, TweenInfo.new(0.2), {BackgroundColor3 = colors.red}):Play()
        end
    end)
end

