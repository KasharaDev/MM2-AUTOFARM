local function switchTab(id)
    if activeTab == id then return end
    activeTab = id
    
    for tabId, data in pairs(tabButtons) do
        local btn = data.btn
        local highlight = data.highlight
        local isActive = (tabId == id)
        
        TweenService:Create(btn, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {
            BackgroundColor3 = isActive and Color3.fromRGB(22, 55, 22) or Color3.fromRGB(10, 14, 10),
            TextColor3 = isActive and Color3.fromRGB(230, 255, 230) or Color3.fromRGB(150, 170, 150)
        }):Play()
        highlight.Visible = isActive
    end
    
    for tabId, frame in pairs(contentFrames) do
        frame.Visible = (tabId == id)
    end
end

local function createContentFrame(id)
